// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int         @id @default(autoincrement())
  telegramId  String?     @unique
  username    String?
  role        String      @default("EMPLOYEE") // "OWNER" or "EMPLOYEE"
  createdAt   DateTime    @default(now())
  timeEntries TimeEntry[]
}

model Wash {
  id              Int      @id @default(autoincrement())
  originalMessage String
  parsedCar       String?
  parsedPrice     Float?
  parsedService   String?
  carType         String? // New field
  addons          String? // New field
  senderName      String
  senderId        String
  createdAt       DateTime @default(now())
}

model BotSession {
  id              Int      @id @default(autoincrement())
  chatId          String   @unique
  step            String   @default("start")
  carType         String?
  service         String?
  basePrice       Float?
  addons          String?
  totalAddonPrice Float    @default(0)
  dealerId        Int?
  updatedAt       DateTime @updatedAt
}

model Dealer {
  id        Int           @id @default(autoincrement())
  name      String
  services  Json
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  batches   DealerBatch[]
  washes    DealerWash[]
}

model DealerBatch {
  id       Int          @id @default(autoincrement())
  dealerId Int
  dealer   Dealer       @relation(fields: [dealerId], references: [id])
  openedAt DateTime     @default(now())
  paidAt   DateTime?
  status   String       @default("OPEN")
  washes   DealerWash[]
}

model DealerWash {
  id          Int         @id @default(autoincrement())
  dealerId    Int
  dealer      Dealer      @relation(fields: [dealerId], references: [id])
  batchId     Int
  batch       DealerBatch @relation(fields: [batchId], references: [id])
  serviceName String
  price       Float
  comments    String?
  senderName  String
  senderId    String
  createdAt   DateTime    @default(now())
}

model InviteToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdBy String // telegramId of the owner
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TimeEntry {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  checkIn    DateTime
  checkOut   DateTime? // Null if currently checked in
  breakHours Float     @default(0)
  totalHours Float?
  createdAt  DateTime  @default(now())
}
